@model IEnumerable<SistemaEnderecos.Models.Endereco>

@{
    ViewData["Title"] = "Meus Endereços";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Meus Endereços</h4>
    <div class="d-flex gap-2">
        <a asp-action="ExportarCsv" class="btn btn-success btn-sm">
            ⬇ Exportar CSV
        </a>
        <a asp-action="Criar" class="btn btn-primary btn-sm">
            + Novo Endereço
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhum endereço cadastrado ainda.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>CEP</th>
                    <th>Logradouro</th>
                    <th>Número</th>
                    <th>Bairro</th>
                    <th>Cidade</th>
                    <th>UF</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var endereco in Model)
                {
                    <tr>
                        <td>@endereco.Cep</td>
                        <td>@endereco.Logradouro @(!string.IsNullOrEmpty(endereco.Complemento) ? $"- {endereco.Complemento}" : "")</td>
                        <td>@endereco.Numero</td>
                        <td>@endereco.Bairro</td>
                        <td>@endereco.Cidade</td>
                        <td>@endereco.Uf</td>
                        <td>
                            <a asp-action="Editar" asp-route-id="@endereco.Id" class="btn btn-outline-primary btn-sm">Editar</a>
                            <form asp-action="Deletar" asp-route-id="@endereco.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Deseja excluir este endereço?')">
                                <button type="submit" class="btn btn-outline-danger btn-sm">Excluir</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}